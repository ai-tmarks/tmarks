---
import Layout from '@/layouts/Layout.astro';
import HeaderNew from '@/components/layout/HeaderNew.astro';
import FooterNew from '@/components/layout/FooterNew';
import { PRICING_PLANS, APP_URL } from '@/lib/constants';
---

<Layout title="定价 - TMarks" description="选择适合你的 TMarks 订阅计划。免费版、专业版、企业版，满足不同需求。">
  <HeaderNew />
  
  <main class="pt-24">
    <!-- Hero Section -->
    <section class="py-20 px-6">
      <div class="container mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">选择适合你的计划</h1>
        <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
          从免费版到企业版，我们为每个人都准备了合适的方案
        </p>
      </div>
    </section>
    
    <!-- Pricing Cards -->
    <section class="py-20 px-6">
      <div class="container mx-auto">
        <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
          {PRICING_PLANS.map((plan) => (
            <div class={`glass rounded-3xl p-8 ${plan.highlighted ? 'border-2 border-primary shadow-2xl shadow-primary/20 scale-105' : ''}`}>
              {plan.highlighted && (
                <div class="inline-block px-4 py-1 bg-foreground text-background rounded-full text-sm font-semibold mb-4">
                  最受欢迎
                </div>
              )}
              
              <h3 class="text-2xl font-bold mb-2">{plan.name}</h3>
              <p class="text-muted-foreground mb-6">{plan.description}</p>
              
              <div class="mb-6">
                <span class="text-5xl font-bold">{plan.price}</span>
                {plan.period && (
                  <span class="text-muted-foreground ml-2">/ {plan.period}</span>
                )}
              </div>
              
              <ul class="space-y-3 mb-8">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span class="text-sm">{feature}</span>
                  </li>
                ))}
              </ul>
              
              <a
                href={plan.id === 'enterprise' ? '/contact' : `${APP_URL}/register`}
                class={`block w-full py-3 rounded-lg text-center font-semibold transition-all ${
                  plan.highlighted
                    ? 'bg-foreground text-background hover:bg-foreground/90'
                    : 'border border-border hover:border-foreground/20 hover:bg-card/50'
                }`}
              >
                {plan.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- FAQ -->
    <section class="py-20 px-6 bg-card/20">
      <div class="container mx-auto max-w-4xl">
        <h2 class="text-4xl font-bold mb-12 text-center">常见问题</h2>
        
        <div class="space-y-6">
          <div class="glass rounded-2xl p-6">
            <h3 class="text-xl font-bold mb-3">免费版有什么限制？</h3>
            <p class="text-muted-foreground">免费版限制 1000 个书签和 100 个标签页组，AI 标签推荐每月 100 次。对于个人用户来说完全够用。</p>
          </div>
          
          <div class="glass rounded-2xl p-6">
            <h3 class="text-xl font-bold mb-3">可以随时取消订阅吗？</h3>
            <p class="text-muted-foreground">当然可以！你可以随时在设置中取消订阅，取消后仍可使用到当前计费周期结束。</p>
          </div>
          
          <div class="glass rounded-2xl p-6">
            <h3 class="text-xl font-bold mb-3">企业版有什么特殊功能？</h3>
            <p class="text-muted-foreground">企业版提供团队协作、自定义域名、SSO 单点登录、专属客户经理、SLA 保障和定制开发服务。</p>
          </div>
          
          <div class="glass rounded-2xl p-6">
            <h3 class="text-xl font-bold mb-3">支持哪些支付方式？</h3>
            <p class="text-muted-foreground">我们支持支付宝、微信支付、信用卡等多种支付方式。</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <FooterNew client:load />
</Layout>

